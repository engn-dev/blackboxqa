{
  "name": "@blackboxqa/browser",
  "version": "0.4.4",
  "private": true,
  "type": "module",
  "description": "Browser-automation CLI. Supervises the embedded blackboxqa-daemon and exposes a scriptable API over named-page persistent browsers.",
  "license": "MIT",
  "keywords": [
    "browser-automation",
    "playwright",
    "ai-agent",
    "scripting",
    "cli",
    "headless"
  ],
  "homepage": "https://github.com/engn-dev/blackboxqa#readme",
  "bugs": "https://github.com/engn-dev/blackboxqa/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/engn-dev/blackboxqa.git",
    "directory": "apps/blackboxqa-browser"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "blackboxqa-browser": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "NOTICE",
    "THIRD-PARTY-LICENSES"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsx src/cli.ts",
    "compile": "tsc --noEmit",
    "test": "pnpm build && vitest run",
    "test:watch": "pnpm build && vitest",
    "clean": "rm -rf dist coverage .turbo",
    "prepack": "pnpm build && cp ../../NOTICE ../../THIRD-PARTY-LICENSES ."
  },
  "devDependencies": {
    "@blackboxqa/cli-kit": "workspace:*",
    "@blackboxqa/config": "workspace:*",
    "@blackboxqa/daemon-client": "workspace:*",
    "@blackboxqa/logger": "workspace:*",
    "@blackboxqa/protocol": "workspace:*",
    "@inquirer/checkbox": "^5.1.5",
    "@inquirer/prompts": "^7.2.1",
    "@types/node": "^20.17.10",
    "commander": "^12.1.0",
    "esbuild": "^0.27.4",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
